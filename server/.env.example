# Database
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/paid-scrims-app

# Server
PORT=4000

# Auth
AUTH_SECRET=your_jwt_secret_key

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT (if using token verification)
JWT_SECRET=your_jwt_secret_key

# ========================
# OneSignal Push Notifications
# ========================
# Get these from OneSignal dashboard: https://dashboard.onesignal.com
# 1. App ID: Found in OneSignal app settings
# 2. REST API Key: Found in OneSignal app settings under "Keys & IDs"

ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key

# Environment (for OneSignal analytics and debugging)
NODE_ENV=production

